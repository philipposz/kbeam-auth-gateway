KBEAM_AUTH_BIND=127.0.0.1:18090
KBEAM_AUTH_PUBLIC_BASE_URL=https://auth.example.com
KBEAM_AUTH_SERVICE_SLUG=example-service
KBEAM_AUTH_SERVICE_NAME=Example Service
KBEAM_AUTH_COOKIE_NAME=kbeam_auth_session
KBEAM_AUTH_COOKIE_DOMAIN=
KBEAM_AUTH_ALLOWED_WALLETS=kaspa:example
KBEAM_AUTH_WALLET_POLICY=allowlist
KBEAM_AUTH_SESSION_TTL_SECONDS=28800
KBEAM_AUTH_CHALLENGE_TTL_SECONDS=300
KBEAM_AUTH_TICKET_TTL_SECONDS=300
KBEAM_AUTH_SECURE_COOKIES=true
KBEAM_AUTH_SIGNER_NETWORK=mainnet
KBEAM_AUTH_SIGNATURE_VERIFIER_MODE=native
KBEAM_AUTH_STORE_BACKEND=sqlite
KBEAM_AUTH_SQLITE_PATH=./var/kbeam-auth-gateway.sqlite3
KBEAM_AUTH_ADMIN_TOKEN=replace-with-long-random-admin-token
KBEAM_AUTH_MAX_PENDING_TICKETS=1000
KBEAM_AUTH_RATE_LIMIT_WINDOW_SECONDS=60
KBEAM_AUTH_RATE_LIMIT_DEVICE_LOGIN=20
KBEAM_AUTH_RATE_LIMIT_TICKET_POLL=120
KBEAM_AUTH_RATE_LIMIT_TICKET_EVENTS=30
KBEAM_AUTH_RATE_LIMIT_CHALLENGE=60
KBEAM_AUTH_RATE_LIMIT_APPROVE=60
KBEAM_AUTH_RATE_LIMIT_ADMIN=120
